<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
<!-- 
	탐색 선택자 종류 중에서 속성탐색 선택자 종류
	  1. 속성과 값에 따른 탐색선택자 
	  	 - 선택한 요소중 지정한 속성과 일치하는 속성있는지 , 없는지의 포함여부를 따져 요소를 선택하는 선택자.
	  	 -  문법
				1-1.  $("요소들선택[속성명]")
	  	 		           선택한 요소들 중에서 속성명이 포함된 요소만 최종 선택함.

				1-2.  $("요소들선택[속성명^=값]")
					   선택한 요소들 중에서 속성값이 명시한 값으로 시작하는 요소만 최종 선택함.
					  
				1-3.  $("요소들선택[속성명$=값]")
					   선택한 요소들 중에서 속성값이 명시한 값으로 끝나는 요소만 최종 선택함.
			
				1-4.  $("요소들선택[속성명*=값]")
					   선택한 요소들 중에서 속성값을 포함하고 있는 요소만 최종 선택함.	
					   
				1-5.  $("요소들선택[속성명=값]")
					   선택한 요소들 중에서  속성명에 대한 값이 완전히 일치하는 요소만 최종 선택함.	   	  
					  
				1-6.  $(":type속성에대한_값")
					  input요소들 중에서 type속성값이 일치하는 요소만 선택합니다.
					 
 -->
  <script src="https://code.jquery.com/jquery-latest.min.js"></script>
  <script>
  	$(function(){
  		
  	  /*
  	  	<a href="http://easyspub.co.kr" target="_blank">EasysPub</a>  최종 선택!
  	  	
  	  	순서1.  $("#wrap a")   ->   <div id="wrap"> 요소 내부에 작성된 모든 <a>후손요소들 선택
  	  	순서2.  $("#wrap a[target]")	 -> 모든 <a>후손요소들 중 target속성이 작성된 <a>후손 요소 한쌍만 최종선택
  	  */
  	  $("#wrap a[target]").css("color","red");	
/*	
1-1.  $("요소들선택[속성명]")
         선택한 요소들 중에서 속성명이 포함된 요소만 최종 선택함.
*/ 	


	/*
	 	<a href="https://naver.com">Naver</a>  최종 선택!
	 	
		순서1.  $("#wrap a")   			 ->   <div id="wrap"> 요소 내부에 작성된 모든 <a>후손요소들 선택
	 	순서2. $("#wrap a[href^=https]")  ->   <a>후손요소들 중에서도 https값으로 시작하는 값이 있는 <a>후손요소들 선택
	*/
	  $("#wrap a[href^=https]").css("color","aqua");
/*
1-2.  $("요소들선택[속성명^=값]")
   선택한 요소들 중에서 속성값이 명시한 값으로 시작하는 요소만 최종 선택함.
*/

	/*
		<a href="http://daum.net">Daum</a>  최종 선택!
		
		순서1.  $("a")              -> 모든 a요소들을 선택 
		순서2.   $("a[href$=net]")  -> a요소들 중에서도  href 속성의 값에 net으로 끝나는 a요소들만 최종 선택
		
	*/
	  $("a[href$=net]").css("color","yellow");
/*
1-3.  $("요소들선택[속성명$=값]")
   선택한 요소들 중에서 속성값이 명시한 값으로 끝나는 요소만 최종 선택함.
*/

	/*
		<a href="http://easyspub.co.kr" target="_blank">EasysPub</a>
		<a href="https://naver.com">Naver</a>
		<a href="http://google.co.kr">Google</a>   들을 최종 선택!
		
		순서1. $("a")     			->  모든 a요소들을 다중 선택
		순서2.  $("a[href *= co]")	->  a요소들 중에서도 href속성에 작성된 전체 문자열값중에서 'co'가 포함된 a요소들 최종선택
	*/
	  $("a[href *= co]").css("background-color","pink");
/*
1-4.  $("요소들선택[속성명*=값]")
   선택한 요소들 중에서 속성값을 포함하고 있는 요소만 최종 선택함.
*/

  	});
  </script>
</head>
<body>
	<div id="wrap">
		<p><a href="http://easyspub.co.kr" target="_blank">EasysPub</a></p>
		<p><a href="https://naver.com">Naver</a></p>
		<p><a href="http://google.co.kr">Google</a></p>
		<p><a href="http://daum.net">Daum</a></p>
	</div>
	
	<form action="#" method="get" id="member_f">
		<p>
			<label for="user_id">아이디</label>
			<input type="text" name="user_id" id="user_id">
		</p>
		<p>
			<label for="user_pw">비밀번호</label>
			<input type="password" name="user_pw" id="user_pw">
		</p>
	</form>
	<script type="text/javascript">
//	1-6.  $(":type속성에대한_값")
//	  							input요소들 중에서 type속성값이 일치하는 요소만 선택합니다.

//해석 :  input요소들 중에서 type속성값이 password와 완전히 일치하는 <input>요소만 최종 선택 
//		 $(":password").css("backgroundColor", "yellow");		
		 $("input[type=password]").css("backgroundColor","yellow");
	
//해석 : input요소들 중에서 type속성값이  "text"인 요소만 선택 
		 $(":text").css("backgroundColor","green");
//		 $("input[type=text]").css("backgroundColor","green");	
	</script>

	
</body>
</html>





